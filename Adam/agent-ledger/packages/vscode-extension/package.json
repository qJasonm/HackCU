{
  "name": "@agent-ledger/vscode-extension",
  "version": "1.0.0",
  "displayName": "Agent Ledger",
  "description": "VS Code extension for Agent Ledger — multi-agent coordination & long-term memory",
  "publisher": "agent-ledger",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@agent-ledger/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "agentLedger.showStatus",
        "title": "Agent Ledger: Show Status"
      },
      {
        "command": "agentLedger.showSidebar",
        "title": "Agent Ledger: Show Sidebar"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-ledger",
          "title": "Agent Ledger",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "agent-ledger": [
        {
          "type": "webview",
          "id": "agentLedger.sidebar",
          "name": "Agent Ledger"
        }
      ]
    }
  }
}
